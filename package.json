{
	"name": "academic-pandoc-template",
	"version": "2.0.0",
	"scripts": {
		"check": "prettier --check .",
		"commit": "cz",
		"format": "prettier --write .",
		"prepare": "husky",
		"changelog": "git-cliff --config cliff.toml",
		"preview": "quarto preview .",
		"preview:docs": "quarto preview .",
		"preview:article": "quarto preview article",
		"preview:presentation": "quarto preview presentation",
		"preview:thesis": "quarto preview thesis",
		"render": "npm run render:docs && npm run render:article && npm run render:presentation && npm run render:thesis",
		"render:docs": "quarto render .",
		"render:article": "quarto render article",
		"render:article:html": "quarto render article --to html",
		"render:article:docx": "quarto render article --to docx",
		"render:article:pdf": "quarto render article --to pdf",
		"render:article:tex": "quarto render article --to latex",
		"render:presentation": "quarto render presentation",
		"render:presentation:html": "quarto render presentation --to revealjs",
		"render:presentation:pdf": "quarto render presentation --to beamer",
		"render:presentation:pptx": "quarto render presentation --to pptx",
		"render:presentation:tex": "quarto render presentation --to latex",
		"render:thesis": "quarto render thesis",
		"render:thesis:docx": "quarto render thesis --to docx",
		"render:thesis:epub": "quarto render thesis --to epub",
		"render:thesis:pdf": "quarto render thesis --to pdf",
		"render:thesis:tex": "quarto render thesis --to latex"
	},
	"devDependencies": {
		"commitizen": "^4.3.1",
		"cz-conventional-changelog": "^3.3.0",
		"git-cliff": "^2.13.1",
		"husky": "^9.1.7",
		"prettier": "^3.8.4"
	},
	"type": "module",
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	}
}
